# 编辑器 / IDE
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ─────────────────────────────────────────────────────────────
# 本地配置 / 密钥
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
